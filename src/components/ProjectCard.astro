---
// Aquí definimos con TypeScript qué datos necesita esta tarjeta
interface Props {
    title: string;
    description: string;
    techStack: string[];
}

// Extraemos las propiedades
const { title, description, techStack } = Astro.props;
---

<div class="p-6 border border-slate-700 rounded-xl bg-slate-800/50 hover:border-slate-500 transition-colors">
    <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-slate-400 mb-4 text-sm leading-relaxed">{description}</p>

    <!-- Recorremos el arreglo de tecnologías (como un bucle for) -->
    <div class="flex flex-wrap gap-2 mt-4">
        {techStack.map((tech) => (
                <span class="px-3 py-1 bg-blue-900/30 text-blue-300 text-xs font-medium rounded-full border border-blue-800/50">
				{tech}
			</span>
        ))}
    </div>
</div>